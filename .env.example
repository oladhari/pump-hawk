# Copy this file to .env and fill in values
# cp .env.example .env

# ── Entry filter overrides (all optional — defaults shown) ────────
# V3_MIN_PC5M=10        # min 5-min price change % to enter
# V3_MAX_PC5M=25        # max 5-min price change % (blocks over-pumped)
# V3_MAX_MCAP=80000     # max market cap USD
# V3_MIN_LIQ=10000      # min liquidity USD (blocks zero-liq rugs)
# V3_MIN_VOL5M=1500     # min 5-min volume USD
# V3_MIN_BUYS5M=20      # min buys in last 5 min
# V3_MAX_BUYS5M=250     # max buys in last 5 min (blocks overcrowded)
# V3_MIN_BOOST=0.01     # min boost amount
# V3_MIN_SCORE=70       # min entry score (0-100)
# V3_MAX_AGE_MIN=60     # max token age in minutes (blocks stale boosts)

# ── Exit strategy overrides ────────────────────────────────────────
# V3_TP1=0.15           # tranche 1 take profit +15% (50% of position)
# V3_TP2=0.30           # tranche 2 take profit +30% (30% of position)
# V3_SL=-0.15           # stop loss -15% (closes all tranches)
# V3_RUNNER_TRAIL=0.12  # runner trailing stop 12% from peak (20% of position)
# V3_MAX_HOLD_S=600     # max hold time in seconds (10 min)
# V3_MAX_POS=10         # max concurrent open positions

# ── Runtime ────────────────────────────────────────────────────────
# BOOST_POLL_MS=60000   # how often to poll Dexscreener boost API (ms)
# SOL_PRICE_USD=150     # SOL/USD estimate (used only for PP price ratio)
